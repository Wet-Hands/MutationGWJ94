; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Daybuilt BaseGodotProject3D"
run/main_scene="uid://bw7yfthex8us"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://b1dl81x75ey8n"

[autoload]

Global="*uid://b0ndy6bcxkioy"
DiscordRPCLoader="*uid://2dimuwgbiemg"
AmbientCG="*uid://cnxneyd8ilml2"
Network="*uid://d1mlvahjd4lhu"
Discord="*uid://d3w1dv2a7d3re"
SteamNetwork="*uid://cp2awgvvtxi5a"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1280
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/ambientcg/plugin.cfg", "res://addons/discord-rpc-gd/plugin.cfg", "res://addons/godotsteam/plugin.cfg")

